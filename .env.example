# ============================================================================
# MYSQL DATABASE CREDENTIALS (For database connection only)
# DO NOT use these to login to the web interface
# ============================================================================
MYSQL_ROOT_PASSWORD=your_secure_mysql_root_password_here
MYSQL_DATABASE=qrcode_pro_db

# ============================================================================
# WEB APPLICATION ADMIN CREDENTIALS (For web interface login only)
# DO NOT use these to connect to the database
# ============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT signing secret (use a long random string, minimum 32 characters)
AUTH_SECRET=your_very_long_random_secret_key_here_min_32_chars

# Application public URL (for QR codes and redirects)
NEXT_PUBLIC_APP_URL=http://172.18.1.3:8090

# ============================================================================
# NOTES:
# - MySQL credentials are for database access only (internal)
# - Admin credentials are for web UI login only
# - These should be DIFFERENT from each other
# - Example:
#   MYSQL_ROOT_PASSWORD=MySQL@2026!Secure123
#   ADMIN_PASSWORD=WebAdmin@2026!Secure456
# ============================================================================
